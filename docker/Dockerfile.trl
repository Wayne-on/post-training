ARG TRL_BASE_IMAGE=post-training:llamafactory
FROM ${TRL_BASE_IMAGE}

ARG TRL_VERSION=0.24.0

ENV PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    HF_HOME=/workspace/.cache/huggingface \
    TRANSFORMERS_CACHE=/workspace/.cache/huggingface \
    TOKENIZERS_PARALLELISM=false \
    PATH=/opt/venv/bin:$PATH

COPY docker/requirements-trl.txt /tmp/requirements-trl.txt
RUN if python -c "import trl; from trl import GRPOConfig, GRPOTrainer; assert trl.__version__ == '${TRL_VERSION}', trl.__version__"; then \
      echo "Existing TRL ${TRL_VERSION} with GRPOTrainer is available; skip dependency install."; \
    else \
      python -m pip install -r /tmp/requirements-trl.txt && \
      python -m pip install --no-deps trl==${TRL_VERSION}; \
    fi

RUN python -c "import importlib.util; assert importlib.util.find_spec('transformers.models.qwen3_5') is not None, 'transformers qwen3_5 support is missing'"

WORKDIR /workspace

CMD ["/bin/bash"]
