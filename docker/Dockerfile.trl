ARG TRL_BASE_IMAGE=post-training:llamafactory
FROM ${TRL_BASE_IMAGE}

ARG TRL_VERSION=0.24.0
ARG MERGEKIT_VERSION=0.1.4

ENV PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    HF_HOME=/workspace/.cache/huggingface \
    TRANSFORMERS_CACHE=/workspace/.cache/huggingface \
    TOKENIZERS_PARALLELISM=false \
    PATH=/opt/venv/bin:$PATH

COPY docker/requirements-trl.txt /tmp/requirements-trl.txt
RUN if python -c "import trl; assert trl.__version__ == '${TRL_VERSION}', trl.__version__"; then \
      echo "Existing TRL ${TRL_VERSION} is available; skip TRL dependency install."; \
    else \
      python -m pip install -r /tmp/requirements-trl.txt && \
      python -m pip install --no-deps trl==${TRL_VERSION}; \
    fi

RUN if python -c "from mergekit.config import MergeConfiguration"; then \
      echo "Existing mergekit is available; skip mergekit install."; \
    else \
      python -m pip install --no-deps mergekit==${MERGEKIT_VERSION}; \
    fi

RUN python -c "import importlib.util; assert importlib.util.find_spec('transformers.models.qwen3_5') is not None, 'transformers qwen3_5 support is missing'; from trl import GRPOConfig, GRPOTrainer; print('TRL GRPO and Qwen3.5 support: OK')"

WORKDIR /workspace

CMD ["/bin/bash"]
