# Copy to .env on the remote machine if you use docker compose.
PROJECT_DIR=/data2/ysh/post-training
CONTAINER_WORKDIR=/root/post-training
HF_HOME=/root/post-training/.cache/huggingface
TRANSFORMERS_CACHE=/root/post-training/.cache/huggingface
HF_TOKEN=
WANDB_API_KEY=
ROOT_PASS=
NFS_MOUNT=/data/test-files
MODEL_ID=Qwen/Qwen3-30B-A3B

# Default: driver 550 / CUDA 12.4 host.
TRAIN_CUDA_IMAGE=nvidia/cuda:12.4.1-cudnn-devel-ubuntu22.04
SERVE_CUDA_IMAGE=nvidia/cuda:12.4.1-cudnn-runtime-ubuntu22.04
TORCH_VERSION=2.6.0
TORCHVISION_VERSION=0.21.0
TORCHAUDIO_VERSION=2.6.0
TORCH_INDEX_URL=https://download.pytorch.org/whl/cu124
TRAIN_IMAGE=post-training:cu124-train
SERVE_IMAGE=post-training:cu124-serve
LLAMA_FACTORY_REF=v0.9.5
LLAMA_FACTORY_IMAGE=post-training:llamafactory-cu124
LLAMA_FACTORY_CONTAINER_NAME=posttrain_lf
LLAMA_FACTORY_SHM_SIZE=128gb
LLAMA_FACTORY_FA2_IMAGE=post-training:llamafactory-cu124-fa2
LLAMA_FACTORY_FA2_CONTAINER_NAME=posttrain_lf_fa2
FLASH_ATTN_VERSION=2.7.4.post1
FA2_TRITON_VERSION=3.2.0
FLA_VERSION=0.4.2
FA2_MAX_JOBS=4
TRL_VERSION=0.24.0
MERGEKIT_VERSION=0.1.4
TRL_BASE_IMAGE=post-training:llamafactory-cu124
TRL_IMAGE=post-training:trl-cu124
TRL_CONTAINER_NAME=posttrain_trl
TRL_SHM_SIZE=128gb
SERVE_HOST_PORT=32001
LLAMA_FACTORY_API_PORT=32002
LLAMA_FACTORY_TENSORBOARD_PORT=32006
LLAMA_FACTORY_WEBUI_PORT=32060
LLAMA_FACTORY_JUPYTER_PORT=32080
LLAMA_FACTORY_FA2_API_PORT=32102
LLAMA_FACTORY_FA2_TENSORBOARD_PORT=32106
LLAMA_FACTORY_FA2_WEBUI_PORT=32160
LLAMA_FACTORY_FA2_JUPYTER_PORT=32180
TRL_TENSORBOARD_PORT=32206
TRL_JUPYTER_PORT=32280

# Fallback for a driver 530 / CUDA 12.1 host or a driver 535 / CUDA 12.2 host.
# Use the same fallback on both machines for 2-node training unless you upgrade
# both hosts to driver 550+.
# TRAIN_CUDA_IMAGE=nvidia/cuda:12.1.1-cudnn8-devel-ubuntu22.04
